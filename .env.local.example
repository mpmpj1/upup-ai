VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxxx

# First-run easiest path: keep true so you can self-register.
# After you finish initial testing, you can switch to false for invite-only use.
VITE_ENABLE_PUBLIC_REGISTRATION=true

# Only switch this to true after you enable GitHub OAuth in Supabase Auth > Providers
# and configure the GitHub Client ID / Client Secret.
VITE_ENABLE_GITHUB_AUTH=false

APP_ENV=development
