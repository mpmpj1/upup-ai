# This file is mainly for local `supabase functions serve`.
# On hosted Supabase Edge Functions, SUPABASE_URL and SUPABASE_SERVICE_ROLE_KEY
# are provided by Supabase automatically.

SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY

# Required for this PoC's retrieval layer.
PERPLEFINA_API_URL=https://YOUR_PERPLEFINA_ENDPOINT
PERPLEFINA_TIMEOUT_MS=120000

# Optional. Leave empty if you have not deployed the market-data sidecar yet.
MARKET_DATA_ADAPTER_URL=http://127.0.0.1:8001/query
